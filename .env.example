# ─── Site URL (Vercel: https://progpt.kz) ───────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run_openssl_rand_base64_32

# ─── Google OAuth (Cloud Console → Credentials → OAuth 2.0 Web) ───────────────
# Redirect URI: http://localhost:3000/api/auth/callback/google
# Production:    https://progpt.kz/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Gemini AI (https://aistudio.google.com/apikey) ───────────────────────────
GEMINI_API_KEY=
# Optional: gemini-2.5-flash (default), gemini-2.5-pro, etc.
# GEMINI_MODEL=gemini-2.5-flash

# ─── tokens.kz Kanban API (MVP) ─────────────────────────────────────────────
# NEXT_PUBLIC_USE_TOKENS_API=true
# TOKENS_API_URL=https://api.tokens.kz/api/v1
# TOKENS_API_BEARER_TOKEN=secret-from-backend-dev
# TOKENS_API_USER_ID=1

# ─── Legacy direct client (optional) ─────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.tokens.kz/api/v1

# ─── Legacy credentials (optional, only if Google OAuth is not configured) ───
# CREDS_JSON=
